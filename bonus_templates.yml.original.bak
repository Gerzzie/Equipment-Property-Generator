# ============================================================
#  RDL Item Generator — Bonus Description Templates
# ============================================================
#  Edit the right-hand strings to change how each bonus
#  appears in the item preview and the generated iteminfo.lua.
#
#  Placeholders (case-sensitive):
#    V   = flat numeric value  (e.g. 5, -3)
#    PCT = value as percent    (e.g. 10%)
#    ARG = resolved argument   (race name, element name, class name, size name, skill name …)
#    EFF = status effect name  (auto-wrapped in brown color)
#    DUR = duration in seconds (autobonus only)
#
#  Lines that start with '#' are comments and are ignored.
#  Save the file — the app reloads it automatically.
# ============================================================

bonus1:
  # ── Core stats ───────────────────────────────────────────
  bStr:            "STR + V"
  bAgi:            "AGI + V"
  bVit:            "VIT + V"
  bInt:            "INT + V"
  bDex:            "DEX + V"
  bLuk:            "LUK + V"
  bAllStats:       "All Stats + V"
  bAgiVit:         "AGI & VIT + V"
  bAgiDexStr:      "STR, AGI & DEX + V"

  # ── Trait stats ──────────────────────────────────────────
  bPow:            "POW + V"
  bSta:            "STA + V"
  bWis:            "WIS + V"
  bSpl:            "SPL + V"
  bCon:            "CON + V"
  bCrt:            "CRT + V"
  bAllTraitStats:  "All Trait Stats + V"

  # ── HP / SP / AP ─────────────────────────────────────────
  bMaxHP:          "MaxHP + V"
  bMaxSP:          "MaxSP + V"
  bMaxAP:          "MaxAP + V"
  bMaxHPrate:      "MaxHP + V%"
  bMaxSPrate:      "MaxSP + V%"
  bMaxAPrate:      "MaxAP + V%"
  bHPrecovRate:    "HP Recovery + V%"
  bSPrecovRate:    "SP Recovery + V%"

  # ── Offense ──────────────────────────────────────────────
  bBaseAtk:        "Basic ATK + V"
  bAtk:            "ATK + V"
  bAtk2:           "ATK2 + V"
  bAtkRate:        "ATK + V%"
  bWeaponAtkRate:  "Weapon ATK + V%"
  bMatk:           "MATK + V"
  bMatk2:          "MATK + V"
  bMatkRate:       "MATK + V%"
  bWeaponMatkRate: "Weapon MATK + V%"
  bCritical:       "CRIT + V"
  bCriticalLong:   "CRIT (ranged) + V"
  bCriticalRate:   "CRIT + V%"
  bCritAtkRate:    "Crit Damage + V%"
  bCritDefRate:    "Crit Damage Received + V%"
  bCriticalDef:    "Anti-Crit + V"

  # ── Trait offense ─────────────────────────────────────────
  bPAtk:           "PAtk + V"
  bPAtkRate:       "PAtk + V%"
  bSMatk:          "SMatk + V"
  bSMatkRate:      "SMatk + V%"
  bRes:            "Res + V"
  bResRate:        "Res + V%"
  bMRes:           "MRes + V"
  bMResRate:       "MRes + V%"
  bHPlus:          "HPlus + V"
  bHPlusRate:      "HPlus + V%"
  bCRate:          "CRate + V"
  bCRateRate:      "CRate + V%"

  # ── Defense ──────────────────────────────────────────────
  bDef:            "DEF + V"
  bDefRate:        "DEF + V%"
  bDef2:           "DEF (VIT) + V"
  bDef2Rate:       "DEF (VIT) + V%"
  bMdef:           "MDEF + V"
  bMdefRate:       "MDEF + V%"
  bMdef2:          "MDEF (INT) + V"
  bMdef2Rate:      "MDEF (INT) + V%"
  bShortWeaponDamageReturn: "Melee Damage Reflect + V%"
  bLongWeaponDamageReturn:  "Ranged Damage Reflect + V%"
  bMagicDamageReturn:       "Magic Damage Reflect + V%"
  bReduceDamageReturn:      "Reduce Reflect Damage + V%"
  bNearAtkDef:     "Melee Damage Reduction + V%"
  bLongAtkDef:     "Ranged Damage Reduction + V%"
  bMagicAtkDef:    "Magic Damage Reduction + V%"
  bMiscAtkDef:     "Misc Damage Reduction + V%"
  bNoWeaponDamage: "Physical Damage Reduction + V%"
  bNoMagicDamage:  "Magic Effect Reduction + V%"
  bNoMiscDamage:   "Misc Damage Reduction + V%"

  # ── Speed / Cast ─────────────────────────────────────────
  bAspd:              "ASPD + V"
  bAspdRate:          "ASPD + V%"
  bFixedCastrate:     "Fixed Cast Time + V%"
  bVariableCastrate:  "Variable Cast Time + V%"
  bFixedCast:         "Fixed Cast Time (ms) + V"
  bVariableCast:      "Variable Cast Time (ms) + V"
  bDelayrate:         "After-cast Delay + V%"
  bSpeedRate:         "Movement Speed + V%"
  bSpeedAddRate:      "Movement Speed + V%"
  bNoCastCancel:      "No Cast Cancel"
  bNoCastCancel2:     "No Cast Cancel (GvG)"

  # ── Hit / Flee ───────────────────────────────────────────
  bHit:              "HIT + V"
  bHitRate:          "HIT + V%"
  bFlee:             "Flee Rate + V"
  bFleeRate:         "Flee Rate + V%"
  bFlee2:            "Perfect Dodge + V"
  bFlee2Rate:        "Perfect Dodge + V%"
  bPerfectHitRate:   "Perfect HIT + V%"
  bPerfectHitAddRate: "Perfect HIT + V%"

  # ── Attack Range ─────────────────────────────────────────
  bAtkRange:       "Attack Range + V"
  bSplashRange:    "Splash Range + V"
  bSplashAddRange: "Splash Range + V"

  # ── HP / SP gain on kill ──────────────────────────────────
  bHPGainValue:       "HP Gain on Kill + V"
  bSPGainValue:       "SP Gain on Kill + V"
  bLongHPGainValue:   "HP Gain on Kill (ranged) + V"
  bLongSPGainValue:   "SP Gain on Kill (ranged) + V"
  bMagicHPGainValue:  "HP Gain on Kill (magic) + V"
  bMagicSPGainValue:  "SP Gain on Kill (magic) + V"

  # ── Healing ──────────────────────────────────────────────
  bHealPower:        "Heal Power + V%"
  bHealPower2:       "Received Heal Power + V%"

  # ── Healing items (flat / no item filter) ────────────────
  bAddItemHealRate:   "Item HP Recovery + V%"
  bAddItemSPHealRate: "Item SP Recovery + V%"

  # ── SP cost ──────────────────────────────────────────────
  bUseSPrate: "SP Consumption + V%"

  # ── Misc ─────────────────────────────────────────────────
  bAddMaxWeight:       "Max Weight + V"
  bBaseExp:            "Base EXP + V%"
  bJobExp:             "Job EXP + V%"
  bNoKnockback:        "No Knockback"
  bNoGemStone:         "No Gemstone Required"
  bIntravision:        "See Hidden"
  bPerfectHide:        "Perfect Hide"
  bRestartFullRecover: "Full Recover on Revive"
  bNoMadoFuel:         "No Mado Fuel"
  bNoWalkDelay:        "No Walk Delay"
  bNoSizeFix:          "Ignore Size Modifier"
  bNoRegen:            "Stop Regen"

  # ── Unbreakable / Unstripable ─────────────────────────────
  bUnbreakableWeapon:  "Indestructible (except in upgrade attempts)."
  bUnbreakableArmor:   "Indestructible (except in upgrade attempts)."
  bUnbreakableHelm:    "Indestructible (except in upgrade attempts)."
  bUnbreakableShield:  "Indestructible (except in upgrade attempts)."
  bUnbreakableGarment: "Indestructible (except in upgrade attempts)."
  bUnbreakableShoes:   "Indestructible (except in upgrade attempts)."
  bUnbreakable:        "Break Chance Reduction + V%"
  bUnstripableWeapon:  "Weapon cannot be removed via Strip skills."
  bUnstripableArmor:   "Armor cannot be removed via Strip skills."
  bUnstripableHelm:    "Helm cannot be removed via Strip skills."
  bUnstripableShield:  "Shield cannot be removed via Strip skills."
  bUnstripable:        "All Equipment cannot be removed via Strip skills."

  # ── Enemy break / steal ───────────────────────────────────
  bBreakWeaponRate: "Break Enemy Weapon + V%"
  bBreakArmorRate:  "Break Enemy Armor + V%"
  bAddStealRate:    "Steal Rate + V%"

  # ── Damage modifiers ──────────────────────────────────────
  bDoubleRate:    "Double Attack + V%"
  bDoubleAddRate: "Double Attack + V%"
  bSkillRatio:    "Skill Ratio + V%"
  bShortAtkRate:  "Melee Damage + V%"
  bLongAtkRate:   "Ranged Damage + V%"
  bClassChange:   "V% chance to change target's class."

  # ── Damage absorb cap ─────────────────────────────────────
  bAbsorbDmgMaxHP:  "Nullify damage that exceeds V% of MaxHP."
  bAbsorbDmgMaxHP2: "Nullify damage that exceeds V% of MaxHP."

  # ── Ignore DEF / MDEF / Res (element / race / class flags) ─
  bIgnoreDefEle:   "Disregards DEF against ARG element enemies."
  bIgnoreMDefEle:  "Disregards MDEF against ARG element enemies."
  bIgnoreDefRace:  "Disregards DEF against ARG enemies."
  bIgnoreMDefRace: "Disregards MDEF against ARG enemies."
  bIgnoreDefClass: "Disregards DEF against ARG class enemies."
  bIgnoreResRace:  "Disregards Res against ARG enemies."
  bIgnoreMResRace: "Disregards MRes against ARG enemies."

# ── bonus1 special-case phrases ─────────────────────────────
# These keys have sign-aware or contextual phrasing.
# Use V for the absolute value; the app handles +/- automatically.
bonus1_special:
  bAtkEle:           "Weapon is endowed with ARG element."
  bDefEle:           "An armor that is enchanted with the ARG Property."

  # SP / HP drain (sign split)
  bSPDrainValue_pos: "Recover V SP on each attack."
  bSPDrainValue_neg: "Drain V SP from its owner on each attack."
  bHPDrainValue_pos: "Recover V HP on each attack."
  bHPDrainValue_neg: "Drain V HP from its owner on each attack."

  # MATK rate (sign split)
  bMatkRate_pos:    "Increases MATK + V%."
  bMatkRate_neg:    "Decreases MATK - V%."
  bWeaponMatkRate_pos: "Increases Weapon MATK + V%."
  bWeaponMatkRate_neg: "Decreases Weapon MATK - V%."

  # Cast time (sign split)
  bCastrate_pos:      "Increases casting time by V%."
  bCastrate_neg:      "Reduces casting time by V%."
  bFixedCastrate_pos: "Increases fixed casting time by V%."
  bFixedCastrate_neg: "Reduces fixed casting time by V%."

  # After-cast delay (sign split)
  bDelayrate_pos:   "Aftercast Delay + V%."
  bDelayrate_neg:   "Aftercast Delay - V%."

  # DEF-ratio attack
  bDefRatioAtkClass: "Deals more damage depending on the target's defense."
  bDefRatioAtkRace:  "Deals more damage depending on the target's defense."
  bDefRatioAtkEle:   "Deals more damage depending on the target's defense."

  # Regen stop (value = 1:HP / 2:SP)
  bNoRegen_1: "Stops natural HP regeneration."
  bNoRegen_2: "Stops natural SP regeneration."

  # Absorb damage cap
  bAbsorbDmgMaxHP:  "Nullifies damage received that exceeds V% of your MaxHP."
  bAbsorbDmgMaxHP2: "Nullifies damage received that exceeds V% of your MaxHP."

  # Double attack
  bDoubleRate:    "Double Attack probability: V% (highest value applied)."
  bDoubleAddRate: "Double Attack probability + V%."

  # Splash range
  bSplashRange:    "Sets splash attack radius to V cells (highest value applied)."
  bSplashAddRange: "Increases splash attack radius by V cells."

  # Enemy break
  bBreakWeaponRate: "Adds a V chance to break the target's weapon on attack."
  bBreakArmorRate:  "Adds a V chance to break the target's armor on attack."

  # Steal
  bAddStealRate: "Increases Steal success rate by V."

  # Class change (1-arg)
  bClassChange: "Adds a V chance to change the attacked monster's class on normal attack."

  # HP / SP gain on kill
  bHPGainValue:      "Recover V HP each time a monster is killed by melee."
  bSPGainValue:      "Recover V SP each time a monster is killed by melee."
  bLongHPGainValue:  "Recover V HP each time a monster is killed by ranged attack."
  bLongSPGainValue:  "Recover V SP each time a monster is killed by ranged attack."
  bMagicHPGainValue: "Recover V HP each time a monster is killed by magic."
  bMagicSPGainValue: "Recover V SP each time a monster is killed by magic."

  # Damage reflect / return
  bShortWeaponDamageReturn: "Reflects V% of received melee damage back to the attacker."
  bLongWeaponDamageReturn:  "Reflects V% of received ranged damage back to the attacker."
  bMagicDamageReturn:       "Adds a V% chance to reflect targeted magic spells back to the attacker."
  bReduceDamageReturn:      "Reduces reflected damage taken by V%."

  # Fixed / Variable cast (flat ms)
  bFixedCast:    "Increases fixed cast time of all skills by Vms."
  bVariableCast: "Increases variable cast time of all skills by Vms."

  # Healing output / received
  bHealPower:  "Increases the effectiveness of healing skills by V%."
  bHealPower2: "Increases HP received from healing skills by V%."

  # Healing items (flat — no item filter)
  bAddItemHealRate:   "Increases HP recovered from all consumable items by V%."
  bAddItemSPHealRate: "Increases SP recovered from all consumable items by V%."

# ── bonus2 ──────────────────────────────────────────────────
bonus2:
  # Race
  bSubRace:           "Adds V% tolerance against ARG monster."
  bAddRace:           "Increase physical damage against ARG monsters by V%."
  bMagicAddRace:      "Increase magical damage against ARG monsters by V%."
  bExpAddRace:        "EXP from ARG + V%"
  bDropAddRace:       "Drop Rate vs ARG + V%"

  # Element (ARG = element name e.g. Fire, Water)
  bSubEle_pos:         "Add a V% resistance against ARG Property attacks."
  bSubEle_neg:         "Receive V% more damage from ARG Property attacks."
  bSubDefEle_pos:      "Add a V% resistance against ARG Property attacks."
  bSubDefEle_neg:      "Receive V% more damage from ARG Property attacks."
  bMagicSubDefEle_pos: "Add a V% magical resistance against ARG Property attacks."
  bMagicSubDefEle_neg: "Receive V% more magical damage from ARG Property attacks."
  bAddEle:             "Increase damage on ARG Property enemies by V%."
  bMagicAddEle:        "Increase magical damage on ARG Property enemies by V%."
  bMagicAtkEle:        "ARG Magic Damage + V%"

  # Class
  bSubClass:          "Adds V% damage reduction against ARG monsters."
  bAddClass:          "Increases physical damage against ARG monsters by V%."
  bMagicAddClass:     "Increases magical damage against ARG monsters by V%."
  bExpAddClass:       "EXP from ARG + V%"
  bDropAddClass:      "Drop Rate vs ARG + V%"

  # Size
  bSubSize:           "Adds V% damage reduction against ARG monsters."
  bWeaponSubSize:     "Adds V% damage reduction against ARG monsters."
  bMagicSubSize:      "Adds V% magical damage reduction against ARG monsters."
  bAddSize:           "Increases physical damage against ARG monsters by V%."
  bMagicAddSize:      "Increases magical damage against ARG monsters by V%."

  # Status effects (EFF = colored effect name, V = percent for resistance)
  bAddEff:            "Inflict EFF on target V% chance"
  bAddEff2:           "Inflict EFF on self V% chance"
  bAddEffWhenHit:     "Inflict EFF on attacker V% chance"
  bResEff:            "Add a V% resistance against EFF."
  bResEff_imm:        "Gain immunity to EFF."

  # Skills (ARG = skill name)
  bSkillAtk:          "ARG damage increased by V%."
  bSkillHeal:         "ARG heal amount increased by V%."
  bSkillHeal2:        "ARG received heal amount increased by V%."
  bSkillUseSP:        "ARG SP cost + V."
  bSkillUseSPrate:    "ARG SP cost + V%."
  bCastrate:          "ARG cast time + V%."
  bFixedCastrate:     "ARG fixed cast time + V%."
  bVariableCastrate:  "ARG variable cast time + V%."
  bSkillDelay:        "ARG delay + Vms."
  bSkillCooldown:     "ARG cooldown + Vms."
  bSkillFixedCast:    "ARG fixed cast + Vms."
  bSkillVariableCast: "ARG variable cast + Vms."

  # CRIT by race
  bCriticalAddRace:   "CRIT vs ARG + V"

  # Ignore DEF / MDEF (percentage — bonus2 with race/class arg)
  bIgnoreDefRaceRate:   "Adds V% defense bypassing on ARG monster."
  bIgnoreMdefRaceRate:  "Adds V% magical defense bypassing on ARG monster."
  bIgnoreDefClassRate:  "Adds V% defense bypassing on ARG monster."
  bIgnoreMdefClassRate: "Adds V% magical defense bypassing on ARG monster."
  bIgnoreMdefRace2Rate: "Disregards V% of the target's MDEF against ARG monsters."
  bIgnoreResRaceRate:   "Disregards V% of the target's Res against ARG monsters."
  bIgnoreMResRaceRate:  "Disregards V% of the target's MRes against ARG monsters."

  # Flat ignore (complete disregard — bonus2 bIgnoreDefRace with no pct)
  bIgnoreDefRace:   "Disregards all DEF of ARG monsters."
  bIgnoreMDefRace:  "Disregards all MDEF of ARG monsters."
  bIgnoreDefClass:  "Disregards all DEF of ARG class monsters."

  # HP / SP vanish on attack
  bHPVanishRate: "Adds a ARG% chance to decrease enemy's HP by V% with normal attack."
  bSPVanishRate: "Adds a ARG% chance to decrease enemy's SP by V% with normal attack."

  # Regen percent
  bRegenPercentHP: "Recover ARG% of MaxHP every Vms."
  bRegenPercentSP: "Recover ARG% of MaxSP every Vms."

  # Drain / Gain by target race / class
  bHPDrainValueRace:  "HP Drain vs ARG + V"
  bSPDrainValueRace:  "SP Drain vs ARG + V"
  bHpDrainValueClass: "HP Drain vs ARG + V"
  bSpDrainValueClass: "SP Drain vs ARG + V"
  bSPGainRace:        "SP Gain on Kill (ARG) + V"

  # Drain rate (chance)
  bHPDrainRate: "When dealing physical damage there's a ARG% chance that you'll recover V% of your damage as HP."
  bSPDrainRate: "When dealing physical damage there's a ARG% chance that you'll recover V% of your damage as SP."

  # Weapon Coma
  bWeaponComaEle:   "Adds a V% chance to inflict Coma on ARG element enemies."
  bWeaponComaRace:  "Adds a V% chance to inflict Coma on ARG enemies."
  bWeaponComaClass: "Adds a V% chance to inflict Coma on ARG class enemies."

  # Damage vs specific monster ID / class
  bAddDamageClass:      "Physical damage against monster ARG + V%."
  bAddMagicDamageClass: "Magical damage against monster ARG + V%."
  bAddDefMonster:       "DEF against monster ARG + V."
  bAddMDefMonster:      "MDEF against monster ARG + V."

  # AutoSpell
  bAutoSpell:        "AutoSpell ARG Lv V on attack"
  bAutoSpellWhenHit: "AutoSpell ARG Lv V when hit"

  # Zeny
  bGetZenyNum:    "Gain 1~ARG Zeny on kill"
  bAddGetZenyNum: "Gain 1~ARG Zeny on kill (stackable)"

  # Coma
  bComaRace:  "Coma vs ARG + V%"
  bComaClass: "Coma vs ARG + V%"

  # Item drop
  bAddMonsterDropItem:   "Adds a chance of gaining 'ARG' each time a monster is killed."
  bAddMonsterIdDropItem: "Adds a chance of gaining 'ARG' each time a specific monster is killed."

  # Monster drop item group
  bAddMonsterDropItemGroup: "Adds a chance of obtaining an item from group ARG when killing a monster."

  # Misc
  bSubSkill:      "Damage from skill ARG + V%"
  bAddSkillBlow:  "Knockback by V cells when using ARG"
  bClassChange:   "V% chance to change monster class"
  bWeaponAtk:     "ATK with weapon type ARG + V"
  bWeaponDamageRate: "Damage with weapon type ARG + V%"

  # Item heal rate by item ID / group
  bAddItemHealRate:        "Item HP Recovery (item ARG) + V%"
  bAddItemSPHealRate:      "Item SP Recovery (item ARG) + V%"
  bAddItemGroupHealRate:   "Item Group HP Recovery (group ARG) + V%"
  bAddItemGroupSPHealRate: "Item Group SP Recovery (group ARG) + V%"

  # HP / SP regeneration / loss over time
  bHPRegenRate: "Gain V HP every ARGms"
  bHPLossRate:  "Lose V HP every ARGms"
  bSPRegenRate: "Gain V SP every ARGms"
  bSPLossRate:  "Lose V SP every ARGms"

  # Add effect on skill use
  bAddEffOnSkill: "V% chance to inflict EFF on target when using ARG."

# ── autobonus trigger phrases ────────────────────────────────
autobonus:
  physical: "Adds a PCT chance INNER for DUR seconds when dealing physical damage."
  magical:  "Adds a PCT chance INNER for DUR seconds when dealing magical damage."
  melee:    "Adds a PCT chance INNER for DUR seconds when dealing melee damage."
  ranged:   "Adds a PCT chance INNER for DUR seconds when dealing ranged damage."
  misc:     "Adds a PCT chance INNER for DUR seconds when dealing misc damage."
  default:  "Adds a PCT chance INNER for DUR seconds when attacking."
